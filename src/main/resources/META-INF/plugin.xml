<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.xepozz.testo</id>
    <name>Testo PHP</name>
    <vendor email="xepozz@list.ru" url="https://github.com/xepozz">Dmitrii Derepko (@xepozz)</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.php</depends>
    <depends optional="true" config-file="coverage.xml">com.intellij.modules.coverage</depends>

    <resource-bundle>messages.TestoBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="PHP"
                fileNames="testo;testo.php;testo.bat"/>
        <runLineMarkerContributor
                language="PHP" order="first"
                implementationClass="com.github.xepozz.testo.tests.TestoTestRunLineMarkerProvider"/>
        <configurationType
                implementation="com.github.xepozz.testo.tests.run.TestoRunConfigurationType"/>
        <runConfigurationProducer
                implementation="com.github.xepozz.testo.tests.run.TestoRunConfigurationProducer"/>
        <runAnything.executionProvider
                implementation="com.github.xepozz.testo.tests.runAnything.TestoRunAnythingProvider"/>

        <programRunner
                implementation="com.github.xepozz.testo.tests.run.TestoDebugRunner"/>
        <implicitUsageProvider
                implementation="com.github.xepozz.testo.references.TestFunctionImplicitUsageProvider"/>
        <iconProvider
                implementation="com.github.xepozz.testo.ui.TestoIconProvider"/>

        <!--        <notificationGroup-->
        <!--                id="Testo"-->
        <!--                displayType="TOOL_WINDOW"-->
        <!--                toolWindowId="Run"-->
        <!--                isLogByDefault="false"-->
        <!--                bundle="messages.TestoBundle"-->
        <!--                key="notification.group"/>-->
        <notificationGroup
                id="Testo"
                displayType="TOOL_WINDOW"
                toolWindowId="Run"
                isLogByDefault="false"
                bundle="messages.TestoBundle"
                key="notification.group"/>

        <!--                <pathMacroFilter implementation="com.jetbrains.php.phpunit.PhpUnitPathMacroFilter" />-->
        <!--        <iconProvider implementation="com.github.xepozz.testo.ui.TestoIconProvider"/>-->

        <!--        <intentionAction>-->
        <!--            <language>PHP</language>-->
        <!--            <className>com.github.xepozz.testo.actions.PhpNewTestIntention</className>-->
        <!--            <categoryKey>intention.group</categoryKey>-->
        <!--            <bundleName>messages.TestoBundle</bundleName>-->
        <!--        </intentionAction>-->

        <internalFileTemplate name="Testo Test"/>
        <defaultLiveTemplates file="/liveTemplates/Testo.xml"/>
        <liveTemplateContext
                contextId="Testo"
                baseContextId="PHP"
                implementation="com.github.xepozz.testo.TestoContext"/>
        <console.folding
                implementation="com.github.xepozz.testo.ui.TestoStackTraceConsoleFolding"/>
        <console.folding
                implementation="com.github.xepozz.testo.tests.console.TestoRepeatedFrameFolding"/>
        <fileBasedIndex
                implementation="com.github.xepozz.testo.index.TestoDataProvidersIndex"/>

        <spellchecker.bundledDictionaryProvider
                implementation="com.github.xepozz.testo.SpellcheckingDictionaryProvider"/>
        <lang.inspectionSuppressor
                language="PHP"
                implementationClass="com.github.xepozz.testo.tests.inspections.TestoInspectionSuppressor"/>
    </extensions>

    <extensions defaultExtensionNs="com.jetbrains.php">
        <testFrameworkType
                implementation="com.github.xepozz.testo.tests.TestoFrameworkType"/>
        <composerConfigClient
                implementation="com.github.xepozz.testo.TestoComposerConfig"/>
    </extensions>

    <projectListeners>
        <listener class="com.github.xepozz.testo.tests.console.TestoConsoleAugmenter"
                  topic="com.intellij.execution.ExecutionListener"/>
    </projectListeners>

    <actions>
        <action id="TestoNewTestFromClass" class="com.github.xepozz.testo.tests.actions.TestoNewTestFromClassAction">
            <add-to-group group-id="PhpNewTestGroup" anchor="last" />
        </action>

        <!-- Variant A (TestoRerunStyle.MIRROR_AWARE): executor-pinned rerun trio, placed BEFORE the platform
             "Rerun" (FakeRerunAction, which mirrors the current executor). Each button hides itself when it would
             duplicate the platform "Rerun", so there are always 3 distinct rerun options. -->
        <group id="Testo.RerunExecutors">
            <action id="Testo.Rerun"
                    class="com.github.xepozz.testo.tests.actions.TestoRerunAction"/>
            <action id="Testo.RerunWithCoverage"
                    class="com.github.xepozz.testo.tests.actions.TestoRerunWithCoverageAction"/>
            <action id="Testo.RerunWithDebugger"
                    class="com.github.xepozz.testo.tests.actions.TestoRerunWithDebuggerAction"/>
            <add-to-group group-id="RunTab.TopToolbar" anchor="before" relative-to-action="Rerun"/>
        </group>

        <!-- Variant B (TestoRerunStyle.SPLIT_BUTTON): single split button replacing the trio + platform "Rerun". -->
        <action id="Testo.RerunSplit"
                class="com.github.xepozz.testo.tests.actions.TestoRerunSplitButtonAction">
            <add-to-group group-id="RunTab.TopToolbar" anchor="before" relative-to-action="Rerun"/>
        </action>

        <!-- Override the platform "Rerun" so it can step aside for the split button in variant B. -->
        <action id="Rerun" overrides="true"
                class="com.github.xepozz.testo.tests.actions.TestoAwareRerunAction"/>

        <!-- Log-level filter: a primary toolbar dropdown on the test run tab. It resolves the current tab's filter from
             context and hides on non-Testo tabs. Placed before the test view options (Sorting / Show Passed). -->
        <group id="Testo.LogLevelFilter"
               class="com.github.xepozz.testo.tests.console.TestoLogLevelFilterAction">
            <add-to-group group-id="RunTab.TopToolbar" anchor="after" relative-to-action="Stop"/>
        </group>

        <group id="Testo.ToolsMenu" text="Testo" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="Testo.ShowChannelIcons"
                    class="com.github.xepozz.testo.tests.console.TestoShowChannelIconsAction"
                    text="Channel Icons"
                    description="Preview the mapping of Testo channel icon hints to IDE icons"/>
            <separator/>
            <action id="Testo.RerunStyle.Mirror"
                    class="com.github.xepozz.testo.tests.actions.TestoRerunStyleMirrorAction"/>
            <action id="Testo.RerunStyle.Split"
                    class="com.github.xepozz.testo.tests.actions.TestoRerunStyleSplitAction"/>
        </group>
        <group id="TestoGenerateGroup">
            <action
                    id="TestoGenerateTestMethod"
                    class="com.github.xepozz.testo.actions.TestoGenerateTestMethodAction"/>
            <separator/>
            <add-to-group group-id="GenerateGroup" anchor="first"/>
        </group>
    </actions>
</idea-plugin>
